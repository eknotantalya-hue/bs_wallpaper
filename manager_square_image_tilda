<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;overflow-x:hidden;background:#f5f5f3;font-family:"Bebas Neue",sans-serif;color:#111}
.wrap{max-width:980px;margin:0 auto;padding:20px 14px 40px}
.site{font-size:1.05rem;letter-spacing:.15em;text-align:center;margin-bottom:1px}
.sub{font-size:.6rem;letter-spacing:.22em;color:#aaa;text-align:center;margin-bottom:14px;font-family:"Arial Black",Arial,sans-serif}
.hint{background:#eee;border:1px solid #ddd;color:#555;font-family:"Arial Black",Arial,sans-serif;font-size:.66rem;line-height:1.7;padding:9px 13px;border-radius:4px;margin-bottom:11px}
.hint b{color:#222}
.hint .accent{color:#FF8700}
.policy{background:#fff;border:1.5px solid #ddd;color:#555;font-family:"Arial Black",Arial,sans-serif;font-size:.62rem;line-height:1.65;padding:11px 13px;border-radius:6px;margin-bottom:11px}
.policy b{color:#111}
.modrow{display:flex;gap:7px;margin-bottom:8px;width:100%;flex-wrap:wrap}
.btn.mod{background:#FF8700;color:#fff;border:1.5px solid #FF8700;font-family:"Arial Black",Arial,sans-serif}
.modmsg{display:none;font-family:"Arial Black",Arial,sans-serif;font-size:.62rem;line-height:1.55;border-radius:6px;padding:10px 12px;margin-bottom:10px}
.modmsg.ok{display:block;background:#eef8ee;border:1px solid #b8d8b8;color:#245a24}
.modmsg.yellow{display:block;background:#fff9e8;border:1px solid #ffd07a;color:#7a4700}
.modmsg.red{display:block;background:#fff0e8;border:1px solid #ffbf99;color:#8a3600}
.modmsg.wait{display:block;background:#f4f4f2;border:1px solid #ddd;color:#555}
.inp-row{display:flex;gap:7px;align-items:center;margin-bottom:12px;flex-wrap:wrap;width:100%}
input{flex:1;min-width:150px;background:#fff;border:1.5px solid #ddd;color:#111;font-family:"Bebas Neue",sans-serif;font-size:.95rem;letter-spacing:.08em;padding:9px 12px;border-radius:4px;outline:none;text-transform:uppercase;-webkit-appearance:none;appearance:none}
input:focus{border-color:#777}
select{background:#fff;border:1.5px solid #ddd;color:#111;font-family:"Bebas Neue",sans-serif;font-size:.85rem;padding:9px;border-radius:4px;outline:none;cursor:pointer;-webkit-appearance:none}
.cc{font-family:Georgia,serif;font-size:.68rem;color:#aaa;white-space:nowrap}
.cc.warn{color:#c84}.cc.over{color:#c44}
.pvs{display:flex;gap:10px;margin-bottom:14px;width:100%;align-items:flex-start;flex-wrap:wrap}
.pv{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;min-width:120px}
.pvl{font-size:.58rem;letter-spacing:.18em;color:#aaa}
.pv canvas{width:100%;height:auto;display:block;border-radius:4px;box-shadow:0 3px 14px rgba(0,0,0,.11)}
.dlr{display:flex;gap:7px;margin-bottom:16px;width:100%;flex-wrap:wrap}
.btn{flex:1;min-width:120px;background:#111;color:#fff;border:none;font-family:"Bebas Neue",sans-serif;font-size:.85rem;letter-spacing:.1em;padding:11px 6px;border-radius:4px;cursor:pointer;text-align:center;-webkit-tap-highlight-color:transparent;touch-action:manipulation}
.btn:active{opacity:.7}
.btn.phone{background:#111;color:#fff;border:1.5px solid #111}
.btn.desktop{background:#111;color:#fff;border:1.5px solid #111}
.btn.square{background:#111;color:#fff;border:1.5px solid #111}
.temp-hide{display:none !important}
.manager-only-note{font-family:"Arial Black",Arial,sans-serif;font-size:.66rem;line-height:1.6;color:#555;background:#fff;border:1px solid #ddd;border-radius:6px;padding:10px 12px;margin-bottom:10px;text-align:center}
.manager-wrap .policy,.manager-wrap .hint,.manager-wrap #savehint,.manager-wrap #cblock,.manager-wrap #btn-mod,.manager-wrap #modmsg,.manager-wrap .ph,.manager-wrap #ps,.manager-wrap #pv-phone,.manager-wrap #pv-desktop{display:none !important}
.manager-wrap .wrap{max-width:620px}.manager-wrap .pv{max-width:420px;margin:0 auto 14px}.manager-wrap .sub{margin-bottom:10px}
.rules-title{font-family:"Arial Black",Arial,sans-serif;font-size:.72rem;line-height:1.5;letter-spacing:.08em;text-align:center;margin:0 0 8px;color:#111}
.rules-list{padding-left:18px;margin:0}.rules-list li{margin:4px 0}
.btn.g{background:#fff;color:#555;border:1.5px solid #ddd}
.savehint{font-family:Georgia,serif;font-size:.68rem;color:#999;text-align:center;margin-bottom:10px;line-height:1.5;display:none;padding:0 8px}
.savehint.show{display:block}
.ph{color:#111;font-size:.6rem;letter-spacing:.2em;margin-bottom:7px;font-family:"Arial Black",Arial,sans-serif}
.ps{display:flex;flex-direction:column;gap:10px}
.pgroup{background:#fff;border:1px solid #ddd;border-radius:6px;padding:10px}
.pgt{font-family:"Arial Black",Arial,sans-serif;font-size:.62rem;letter-spacing:.12em;color:#FF8700;margin-bottom:7px}
.plang{font-family:"Arial Black",Arial,sans-serif;font-size:.54rem;letter-spacing:.12em;color:#aaa;margin:7px 0 4px}
.pbuttons{display:flex;flex-wrap:wrap;gap:5px}
.pb{background:#fff;border:1px solid #ddd;color:#111;font-family:"Bebas Neue",sans-serif;font-size:.72rem;letter-spacing:.04em;padding:5px 9px;border-radius:3px;cursor:pointer;-webkit-tap-highlight-color:transparent;touch-action:manipulation}
.pb:active{background:#eee;color:#111}
.cblock{background:#fff;border:1.5px solid #ddd;border-radius:6px;padding:14px;margin-bottom:14px;width:100%}
.cblock,.cblock h3,.cblock label,.cblock input,.cblock select,.cblock span{font-family:"Arial Black",Arial,sans-serif}
.cblock h3{font-size:.76rem;letter-spacing:.08em;color:#888;margin-bottom:10px}
.cfield{display:flex;flex-direction:column;gap:3px;margin-bottom:10px}
.cfield label{font-family:"Arial Black",Arial,sans-serif;font-size:.68rem;color:#888}
.cfield input,.cfield select{background:#f4f4f2;border:1.5px solid #ddd;color:#111;
  font-family:"Arial Black",Arial,sans-serif;font-size:.78rem;letter-spacing:.02em;padding:8px 10px;border-radius:4px;outline:none;width:100%;
  -webkit-appearance:none;appearance:none}
.cfield input:focus,.cfield select:focus{border-color:#777}
.crow{display:flex;gap:8px}
.crow .cfield{flex:1}
.ccheck{display:flex;align-items:flex-start;gap:8px;margin-bottom:8px;font-family:"Arial Black",Arial,sans-serif;font-size:.62rem;color:#666;line-height:1.55}
.ccheck input[type=checkbox]{box-sizing:border-box;margin:2px 0 0 0!important;display:inline-block!important;flex:0 0 16px!important;min-width:16px!important;width:16px!important;height:16px!important;padding:0!important;border:1.5px solid #111!important;border-radius:2px!important;background:#fff!important;cursor:pointer;-webkit-appearance:checkbox!important;appearance:checkbox!important;accent-color:#111}
.ccheck a{color:#111}
.cerr{font-family:Georgia,serif;font-size:.68rem;color:#c44;margin-top:4px;display:none}
.btn.disabled{opacity:.4;pointer-events:none;cursor:default}
@media(max-width:500px){
  .pvs{flex-direction:column}
  .pv{width:100%}
  .dlr{flex-direction:column}
}
</style>
