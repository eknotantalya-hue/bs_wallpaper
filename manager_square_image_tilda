function updateActionButtons(){
  const formOK = validateForm(false);
  const sig = phraseModerationSignature();
  const approved = formOK && (moderationState === 'green' || moderationState === 'yellow') && lastModeratedSignature === sig;
  const modBtn = document.getElementById('btn-mod');
  if(modBtn) modBtn.classList.toggle('disabled', !formOK);
  ['btn-p','btn-d','btn-s'].forEach(id=>{
    const b = document.getElementById(id);
    if(b){ b.classList.toggle('disabled', !approved); }
  });
  return approved;
}

function runModeration(){
  bwInput(true);
  if(!validateForm(true)) return;
  const raw = normalizeInputValue(document.getElementById('inp').value||'', true);
  const result = checkPhraseModeration(raw);
  lastModeratedSignature = phraseModerationSignature();
  lastModerationResult = result;

  if(result.status === 'GREEN'){
    moderationState = 'green';
    setModerationMessage('ok', MODERATION_TEXT_GREEN);
    updateActionButtons();
    bwGo();
    alert(MODERATION_TEXT_GREEN);
    return true;
  }

  if(result.status === 'YELLOW'){
    moderationState = 'yellow';
    setModerationMessage('yellow', MODERATION_TEXT_YELLOW);
    updateActionButtons();
    bwGo();
    alert(MODERATION_TEXT_YELLOW);
    return true;
  }

  moderationState = 'red';
  setModerationMessage('red', MODERATION_TEXT_RED);
  updateActionButtons();
  bwGo();
  alert(MODERATION_TEXT_RED);

  // RED goes to PIM immediately because download is blocked.
  sendToPim(collectCustomerPayloadBase({
    format:'blocked', filename:'', download_blocked:'true'
  }));
  return false;
}

const NAME_CLEAN_RE = /[^A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü ]/g;
const NAME_INVALID_RE = /[^A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü ]/;

function sanitizeNameInput(){
  const el = document.getElementById('cname');
  if(!el) return;
  el.value = String(el.value||'')
    .replace(NAME_CLEAN_RE,'')
    .replace(/ {2,}/g,' ')
    .replace(/^ +/,'');
}

function defaultPhonePrefix(){
  const el = document.getElementById('cphone');
  if(el && !String(el.value||'').trim()) el.value = '+90';
}

function sanitizePhoneInput(){
  const el = document.getElementById('cphone');
  if(!el) return;
  let raw = String(el.value||'')
    .replace(/[^\d+]/g,'')     // only digits and plus
    .replace(/(?!^)\+/g,'');    // plus only at the beginning

  if(!raw){ el.value = ''; return; }
  if(raw[0] !== '+') raw = '+' + raw;

  const digits = raw.replace(/\D/g,'').slice(0,13); // allow total length 12-14 including +
  el.value = digits ? ('+' + digits) : '';
}

function phoneDigitsOnly(){
  return (document.getElementById('cphone').value||'').replace(/\D/g,'');
}

function phoneForPim(){
  const digits = phoneDigitsOnly();
  // Turkey default: send the same 10-digit local number as the earlier working PIM rows.
  if(digits.startsWith('90') && digits.length === 12) return digits.slice(2);
  if(digits.startsWith('0') && digits.length === 11) return digits.slice(1);
  // Other countries: send digits only, without plus, so Google Sheets does not treat it as a formula.
  return digits;
}

function validateForm(updateButtons=true){
  sanitizeNameInput();
  const nameRaw = (document.getElementById('cname').value||'').trim();
  const nameOK = nameRaw.replace(/\s/g,'').length >= 2 && !NAME_INVALID_RE.test(nameRaw);

  const phoneValue = (document.getElementById('cphone').value||'').trim();
  const phoneDigits = phoneDigitsOnly();
  const phoneOK = /^\+\d{11,13}$/.test(phoneValue) && phoneValue.length >= 12 && phoneValue.length <= 14 && phoneDigits.length >= 11 && phoneDigits.length <= 13;

  const social = document.getElementById('csocial').value || '';
  const nick = (document.getElementById('cnick').value||'').trim();
  const kvkk = document.getElementById('ckvkk').checked;
  const pub = document.getElementById('cpub').checked;
  const phraseOK = visLen(document.getElementById('inp').value||'') > 0;

  const ok = nameOK && phoneOK && !!social && nick.length >= 2 && kvkk && pub && phraseOK;
  if(updateButtons){ updateActionButtons(); }
  return ok;
}

function bwInput(finalClean=false){
  const inp = document.getElementById('inp');
  const cur = inp.selectionStart || 0;
  const before = inp.value;
  const beforeSig = phraseModerationSignature();
  let val = normalizeInputValue(before, finalClean);

  // Max two | (3 rows max).
  const pipes = val.split('|').length - 1;
  if(pipes > 2){
    let count = 0;
    val = val.replace(/\|/g, m => { count++; return count <= 2 ? m : ''; });
  }

  // Max 15 visible chars per row, preserving % markers. Spaces count as visible chars.
  // Total limit remains 45 because max 3 rows × 15 chars.
  val = val.split('|').map(seg => {
    let count = 0, out = '';
    for(const ch of seg){
      if(ch !== '%') count++;
      if(count > 15) break;
      out += ch;
    }
    return out;
  }).join('|');

  if(val !== before){
    const delta = before.length - val.length;
    inp.value = val;
    const pos = Math.max(0, cur - Math.max(delta,0));
    try{ inp.setSelectionRange(pos,pos); }catch(e){}
  }

  const len = visLen(inp.value);
  const cc = document.getElementById('cc');
  cc.textContent = len+'/45';
  cc.className = 'cc'+(len>45?' over':len>38?' warn':'');

  const afterSig = phraseModerationSignature();
  const phraseChanged = !lastModeratedSignature || afterSig !== lastModeratedSignature;
  if(phraseChanged){
    moderationState = 'pending';
    lastModeratedSignature = '';
    lastModerationResult = null;
    setModerationMessage('', '');
  }
  updateActionButtons();
  bwGo();
}

// Extra zones make the main body of accented/descending letters the same visual height as normal letters.
// top: accents above rope/base body; bottom: descenders below body. Fractions are relative to body height.
const LETTER_EXTRA = {
  'İ':{top:.24,bottom:0}, 'Ü':{top:.22,bottom:0}, 'Ğ':{top:.18,bottom:0}, 'Ö':{top:.22,bottom:0},
  'Ё':{top:.24,bottom:0}, 'Й':{top:.18,bottom:0},
  'Ş':{top:0,bottom:.20}, 'Ç':{top:0,bottom:.22}, 'Q':{top:0,bottom:.20},
  'Ц':{top:0,bottom:.18}, 'Щ':{top:0,bottom:.18}, 'Д':{top:0,bottom:.18}
};
function letterExtra(ch){ return LETTER_EXTRA[ch] || {top:0,bottom:0}; }

function letterDims(ch, bodyH){
  const d = SL[ch];
  const ex = letterExtra(ch);
  if(!d){
    const h = bodyH * (1 + ex.top + ex.bottom);
    return { d:null, v:null, sc:1, lW:bodyH*.75, lH:h, anchorY:ex.top*bodyH + bodyH*.09 };
  }
  const v = vbP(d.vb);
  const canvasH = bodyH * (1 + ex.top + ex.bottom);
  const sc = canvasH / v.h;
  return { d, v, sc, lW:v.w*sc, lH:canvasH, anchorY:ex.top*bodyH + bodyH*.09 };
}

// Build letter on offscreen canvas. Uses evenodd so Corel/SVG holes stay transparent.
function buildLetter(ch, bodyH, letterColor){
  const dim = letterDims(ch, bodyH);
  const oc = document.createElement('canvas');
  oc.width  = Math.max(1, Math.ceil(dim.lW));
  oc.height = Math.max(1, Math.ceil(dim.lH));
  const cx = oc.getContext('2d');
  if(MANAGER_MODE && ch==='*'){
    const size = Math.min(oc.width, oc.height)*0.86;
    const cx0 = oc.width/2, cy0 = oc.height/2;
    cx.save();
    cx.beginPath();
    cx.arc(cx0, cy0, size/2, 0, Math.PI*2);
    cx.fillStyle = '#fff';
    cx.fill();
    cx.lineWidth = Math.max(2, size*0.08);
    cx.strokeStyle = '#D92626';
    cx.stroke();
    cx.fillStyle = '#D92626';
    cx.font = '900 '+Math.max(12, Math.round(size*0.33))+"px 'Arial Black',Arial,sans-serif";
    cx.textAlign='center';
    cx.textBaseline='middle';
    cx.fillText('18+', cx0, cy0+1);
    cx.restore();
  } else if(dim.d){
    cx.save();
    cx.scale(dim.sc, dim.sc);
    cx.fillStyle = letterColor;
    dim.d.p.forEach(pd => cx.fill(new Path2D(pd), 'evenodd'));
    cx.restore();
  } else {
    cx.fillStyle = letterColor;
    cx.font = '900 '+Math.round(bodyH*.82)+"px 'Arial Black',Impact,sans-serif";
    cx.textAlign = 'center';
    cx.textBaseline = 'middle';
    cx.fillText(ch, dim.lW/2, dim.lH/2);
  }
  return { canvas:oc, lW:dim.lW, lH:dim.lH, anchorY:dim.anchorY };
}

// Measure raw pixel width of a row at given bodyH
function measureRow(text, bodyH, s){
  const CG=4*s, WG=bodyH*1.0;
  const chars = Array.from(bsUpper(stripAccent(text)));
  let w = 0;
  chars.forEach((ch,i)=>{
    if(ch===' '){ w+=WG; return; }
    w += letterDims(ch, bodyH).lW;
    if(i<chars.length-1 && ch!==' ' && chars[i+1]!==' ') w+=CG;
  });
  return w;
}

function drawRow(ctx, rawText, W, cY, pal, s, lH, SAG){
  const CG=4*s, WG=lH*1.0, EXT=60*s;
  // Build color map from rawText (with % markers)
  const colorMap = buildColorMap(rawText, pal.letter);
  // Filter to visible chars (no spaces handled separately)
  // chars array = all chars including spaces, with colors
  const chars = colorMap; // [{ch, color}]

  // Compute widths
  const ws = chars.map(({ch})=>{
    if(ch===' ') return WG;
    return letterDims(ch, lH).lW;
  });

  let raw=0;
  chars.forEach(({ch},i)=>{
    raw+=ws[i];
    if(i<chars.length-1 && ch!==' ' && chars[i+1].ch!==' ') raw+=CG;
  });

  // No extra scaling here — lH already set by caller for uniform size
  const totalW=raw, lHs=lH, cg=CG, ext=EXT;
  const x0=W/2-totalW/2-ext, x1=W/2+totalW/2+ext, span=x1-x0;
  const hIY=lHs*0.09, rBY=cY-lHs/2+hIY;

  // Draw rope
  ctx.save();
  ctx.strokeStyle=pal.rope; ctx.lineWidth=1.4*s; ctx.lineCap='round';
  ctx.beginPath();
  for(let i=0;i<=120;i++){
    const t=i/120, rx=x0+t*span, ry=rBY+sagAt(t,SAG);
    i===0?ctx.moveTo(rx,ry):ctx.lineTo(rx,ry);
  }
  ctx.stroke(); ctx.restore();

  // Draw letters
  let x = W/2-totalW/2;
  chars.forEach(({ch,color},i)=>{
    const w=ws[i];
    if(ch===' '){ x+=w; return; }
    const lcx=x+w/2;
    const t=(lcx-x0)/span;
    const rY=rBY+sagAt(t,SAG);
    const sl=sagSlope(t,SAG,span), ang=Math.atan(sl)*0.65;
    const lb=buildLetter(ch, lHs, color);
    ctx.save();
    // Align rope to the two punched holes inside the body, not to dots/diacritics.
    ctx.translate(lcx, rY - lb.anchorY + lb.lH/2);
    ctx.rotate(ang);
    // Soft shadow via globalAlpha trick
    ctx.globalAlpha=0.12;
    ctx.filter='blur('+(2*s)+'px)';
    ctx.drawImage(lb.canvas, -lb.lW/2+2*s, -lb.lH/2+3*s);
    ctx.filter='none'; ctx.globalAlpha=1;
    ctx.drawImage(lb.canvas, -lb.lW/2, -lb.lH/2);
    ctx.restore();
    const nextCh = chars[i+1];
    x += w + (nextCh && nextCh.ch!==' ' ? cg : 0);
  });
}

// Позиция подписи blacksymbols.com по форматам.
// Чем больше коэффициент, тем выше подпись от нижнего края.
// p=телефон 9:16 — заметно выше; d=desktop — как было; s=квадрат — немного выше.
const LOGO_Y_FACTOR = { p: 3.35, d: 1.80, s: 2.25 };

function renderTo(cv, W, H, raw, bgKey, fmt){
  cv.width=W; cv.height=H;
  const ctx=cv.getContext('2d');
  const pal=PAL[bgKey]||PAL.w;
  const s=W/1080;
  ctx.fillStyle=pal.bg; ctx.fillRect(0,0,W,H);

  const rows=parseRows(raw);
  if(!rows.length) return;

  // Uniform letter height: find longest row, scale so it fills 46% width
  const BH=108*s;
  let maxRaw=0;
  rows.forEach(row=>{
    const rw=measureRow(row,BH,s);
    if(rw>maxRaw) maxRaw=rw;
  });
  const targetW=W*0.46;
  const gScl=maxRaw>0?targetW/maxRaw:1;
  // Cap at 180*s so it doesn't get too big for very short phrases
  const lH=Math.min(BH*gScl, 180*s);
  const SAG=34*s;
  const RG=lH*0.52;
  const totalH=rows.length*lH+(rows.length-1)*RG;
  const sCY=H/2-totalH/2+lH/2;

  rows.forEach((row,i)=>{
    drawRow(ctx, row, W, sCY+i*(lH+RG), pal, s, lH, SAG);
  });

  // Logo / site label
  ctx.save();
  ctx.textAlign='center';
  ctx.fillStyle=pal.letter;
  ctx.font=Math.round(24*s)+"px 'Bebas Neue',sans-serif";
  const factor = LOGO_Y_FACTOR[fmt] || 1.8;
  const logoY = Math.max(40*s, Math.min(H-30*s, H-lH*factor));
  ctx.fillText('blacksymbols.com', W/2, logoY);
  ctx.restore();
}

const CFGS={p:{W:1080,H:1920},d:{W:1920,H:1080},s:{W:1080,H:1080}};
const CVS={p:document.getElementById('cp'),d:document.getElementById('cd'),s:document.getElementById('cs')};
const CACHE={};

function bwGo(){
  const raw = getRenderPhraseRaw();
  const bg=document.getElementById('bg').value;
  for(const[key,cfg]of Object.entries(CFGS)){
    const off=document.createElement('canvas');
    off.width=cfg.W; off.height=cfg.H;
    renderTo(off,cfg.W,cfg.H,raw,bg,key);
    CACHE[key]=off;
    const cv=CVS[key];
    cv.width=cfg.W; cv.height=cfg.H;
    cv.getContext('2d').drawImage(off,0,0);
  }
}

function isPimUrlReady(){
  return /^https:\/\/script\.google\.com\/macros\/s\/.+\/exec(\?.*)?$/.test(APPS_SCRIPT_URL);
}

function getSourcePageUrl(){
  // В iframe location.href = GitHub Pages. Для PIM нам нужен адрес страницы сайта Tilda.
  // document.referrer обычно даёт https://blacksymbols.com/wallpaper
  return document.referrer || location.href;
}

function sendToPim(payload){
  if(!isPimUrlReady()){
    console.warn('PIM URL is not set correctly. Paste the deployed Apps Script /exec URL into the single APPS_SCRIPT_URL constant only.');
    return false;
  }

  // Самый стабильный способ для Google Apps Script Web App из GitHub/Tilda iframe:
  // обычный HTML form POST в скрытый iframe. Нет CORS preflight, Apps Script получает e.parameter.
  try{
    const frameName = 'bs_pim_sink';
    let frame = document.querySelector('iframe[name="'+frameName+'"]');
    if(!frame){
      frame = document.createElement('iframe');
      frame.name = frameName;
      frame.style.display = 'none';
      document.body.appendChild(frame);
    }

    const form = document.createElement('form');
    form.method = 'POST';
    form.action = APPS_SCRIPT_URL;
    form.target = frameName;
    form.style.display = 'none';

    Object.keys(payload).forEach(k=>{
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = k;
      input.value = payload[k] == null ? '' : String(payload[k]);
      form.appendChild(input);
    });

    document.body.appendChild(form);
    form.submit();
    setTimeout(()=>{ try{ form.remove(); }catch(e){} }, 5000);
    return true;
  }catch(err){
    console.warn('PIM form post failed, trying fetch', err);
  }

  // Запасной вариант. Ответ не читаем из-за no-cors, но POST должен уйти.
  fetch(APPS_SCRIPT_URL,{
    method:'POST', mode:'no-cors', redirect:'follow',
    headers:{'Content-Type':'text/plain;charset=utf-8'},
    body:JSON.stringify(payload)
  }).catch(err=>console.warn('PIM fetch failed', err));
  return true;
}

function bwDl(key){
  if(!validateForm()) return;
  if(!updateActionButtons()){
    setModerationMessage('wait', MODERATION_TEXT_NEED);
    alert(MODERATION_TEXT_NEED);
    return;
  }
  const off=CACHE[key]; if(!off) return;
  const active = getActiveModerationResult() || checkPhraseModeration(document.getElementById('inp').value||'');
  const slugSource = active.phrase_visual_raw || active.phrase_original_raw || 'BS';
  const slug=stripAccent(slugSource).replace(/[|]/g,'-').trim().slice(0,18).replace(/[^A-Za-zА-Яа-я0-9*]+/g,'_').replace(/_+/g,'_').replace(/^_|_$/g,'').toLowerCase() || 'bs';
  const fname='bs_'+key+'_'+slug+'.jpg';

  // GREEN and YELLOW go to PIM only when the user clicks a download button.
  // YELLOW sends both original phrase and masked visual phrase.
  sendToPim(collectCustomerPayloadBase({
    format:key, filename:fname, download_blocked:'false'
  }));

  // Download image
  off.toBlob(function(blob){
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url; a.download=fname;
    a.style.position='fixed'; a.style.top='-9999px';
    document.body.appendChild(a); a.click();
    setTimeout(()=>{ document.body.removeChild(a); URL.revokeObjectURL(url); },3000);
  },'image/jpeg',0.96);
}


