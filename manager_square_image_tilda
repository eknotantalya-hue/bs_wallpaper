function normalizeForModeration(text){
  return String(text||'')
    .replace(/%/g,' ')
    .replace(/\|/g,' ')
    .replace(/Ё/g,'Е').replace(/ё/g,'е')
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g,'')
    .replace(/İ/g,'I').replace(/ı/g,'I')
    .toUpperCase()
    .replace(/[^A-ZА-ЯЕ0-9 ]+/g,' ')
    .replace(/\s+/g,' ')
    .trim();
}

function phraseModerationSignature(){
  return normalizeForModeration(normalizeInputValue(document.getElementById('inp').value||'', true));
}

function escapeRegExp(str){ return String(str).replace(/[.*+?^${}()|[\]\\]/g,'\\$&'); }

function termToRegExp(term){
  let t = normalizeForModeration(term);
  const prefix = /\*$/.test(String(term));
  if(prefix) t = t.replace(/\*+$/,'');
  if(!t) return null;
  const pattern = escapeRegExp(t).replace(/\\ /g,'\\s+');
  return new RegExp('(^|\\s)' + pattern + (prefix ? '[A-ZА-ЯЕ0-9]*' : '') + '(?=\\s|$)', 'i');
}

function findRuleHits(normalized, rules){
  const hits = [];
  rules.forEach(rule=>{
    (rule.terms||[]).forEach(term=>{
      const re = termToRegExp(term);
      if(re && re.test(normalized)) hits.push({cat:rule.cat, term:normalizeForModeration(term).replace(/\*+$/,'')});
    });
  });
  return hits;
}

function isYellowWord(word){
  const norm = normalizeForModeration(word);
  return !!findRuleHits(norm, YELLOW_RULES).length;
}

function preferredMaskPosition(word){
  const chars = Array.from(word);
  if(chars.length <= 2) return Math.min(1, chars.length-1);
  const norm = normalizeForModeration(word);
  const has = stem => norm.startsWith(stem);
  if(has('ПИЗД') || has('БЛЯ') || has('ХУ') || has('СУК') || has('ЕБ') || has('ЕБА') || has('ПИД')) return Math.min(2, chars.length-2);
  if(has('SIK') || has('AMK') || has('FUCK') || has('CUNT') || has('DICK') || has('PUSS') || has('SHIT') || has('BITCH') || has('OROSPU') || has('AMINA') || has('AMCIK')) return 1;
  return chars.length >= 5 ? 2 : 1;
}

function maskOneInternalLetter(word){
  const chars = Array.from(word);
  if(chars.length <= 1) return '*';
  const alpha = /[A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü]/;
  const candidates = [];
  for(let i=1;i<chars.length-1;i++){
    if(alpha.test(chars[i])) candidates.push(i);
  }
  let pos = preferredMaskPosition(word);
  if(candidates.length){
    const exact = candidates.includes(pos) ? pos : candidates.find(i=>i>=pos) ?? candidates[candidates.length-1];
    pos = exact;
  } else {
    pos = chars.length === 2 ? 1 : Math.floor(chars.length/2);
  }
  chars[pos] = '*';
  return chars.join('');
}

function maskProfanityInPhrase(raw){
  const masked = [];
  const seen = new Set();
  const phrase = String(raw||'').replace(/[A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü]+/g, word=>{
    if(isYellowWord(word)){
      const out = maskOneInternalLetter(word);
      const key = bsUpper(word) + '→' + bsUpper(out);
      if(!seen.has(key)){ seen.add(key); masked.push(key); }
      return out;
    }
    return word;
  });
  return {phrase_visual_raw:phrase, masked_words:masked};
}

function checkPhraseModeration(raw){
  const phrase_original_raw = normalizeInputValue(raw||'', true);
  const normalized = normalizeForModeration(phrase_original_raw);
  const redHits = findRuleHits(normalized, RED_RULES);
  if(redHits.length){
    return {
      status:'RED', ok:false, download_allowed:false,
      phrase_original_raw,
      phrase_original:bsUpper(phrase_original_raw.replace(/\|/g,' ').replace(/%/g,'').replace(/\s+/g,' ').trim()),
      phrase_clean:normalized,
      phrase_visual_raw:'BLACK SYMBOLS',
      phrase_visual:'BLACK SYMBOLS',
      masked_words:[],
      detected_terms:[...new Set(redHits.map(h=>h.term))],
      categories:[...new Set(redHits.map(h=>h.cat))],
      moderation_reason:'HIGH_RISK_CONTENT',
      visual_mode:'BLOCKED'
    };
  }
  const masked = maskProfanityInPhrase(phrase_original_raw);
  const yellowHits = findRuleHits(normalized, YELLOW_RULES);
  if(yellowHits.length){
    return {
      status:'YELLOW', ok:true, download_allowed:true,
      phrase_original_raw,
      phrase_original:bsUpper(phrase_original_raw.replace(/\|/g,' ').replace(/%/g,'').replace(/\s+/g,' ').trim()),
      phrase_clean:normalized,
      phrase_visual_raw:masked.phrase_visual_raw,
      phrase_visual:bsUpper(masked.phrase_visual_raw.replace(/\|/g,' ').replace(/%/g,'').replace(/\s+/g,' ').trim()),
      masked_words:masked.masked_words,
      detected_terms:[...new Set(yellowHits.map(h=>h.term))],
      categories:[...new Set(yellowHits.map(h=>h.cat))],
      moderation_reason:'PROFANITY_MASKED',
      visual_mode:'MASKED'
    };
  }
  return {
    status:'GREEN', ok:true, download_allowed:true,
    phrase_original_raw,
    phrase_original:bsUpper(phrase_original_raw.replace(/\|/g,' ').replace(/%/g,'').replace(/\s+/g,' ').trim()),
    phrase_clean:normalized,
    phrase_visual_raw:phrase_original_raw,
    phrase_visual:bsUpper(phrase_original_raw.replace(/\|/g,' ').replace(/%/g,'').replace(/\s+/g,' ').trim()),
    masked_words:[], detected_terms:[], categories:[],
    moderation_reason:'AUTO_OK', visual_mode:'ORIGINAL'
  };
}

function setModerationMessage(type, text){
  const el = document.getElementById('modmsg');
  if(!el) return;
  el.className = 'modmsg' + (type ? ' ' + type : '');
  el.textContent = text || '';
}

function resetModeration(showNeed=false){
  moderationState = 'pending';
  lastModeratedSignature = '';
  lastModerationResult = null;
  if(showNeed) setModerationMessage('wait', MODERATION_TEXT_NEED);
  else setModerationMessage('', '');
  updateActionButtons();
}

function getActiveModerationResult(){
  const sig = phraseModerationSignature();
  if(lastModeratedSignature && sig === lastModeratedSignature && lastModerationResult){ return lastModerationResult; }
  return null;
}

function getRenderPhraseRaw(){
  const raw = document.getElementById('inp').value || '';
  const active = getActiveModerationResult();
  if(active && active.status === 'YELLOW') return active.phrase_visual_raw || raw || 'BLACK SYMBOLS';
  if(active && active.status === 'RED') return 'BLACK SYMBOLS';
  return raw || 'BLACK SYMBOLS';
}

function collectCustomerPayloadBase(extra={}){
  const raw = normalizeInputValue(document.getElementById('inp').value||'', true);
  const active = getActiveModerationResult() || checkPhraseModeration(raw);
  const pub = document.getElementById('cpub').checked;
  return Object.assign({
    created_at:new Date().toISOString(),
    source:'wallpaper',
    phrase:active.phrase_original,
    phrase_raw:active.phrase_original_raw,
    phrase_original:active.phrase_original,
    phrase_original_raw:active.phrase_original_raw,
    phrase_clean:active.phrase_clean,
    phrase_visual:active.phrase_visual,
    phrase_visual_raw:active.phrase_visual_raw,
    masked_words:(active.masked_words||[]).join(','),
    detected_terms:(active.detected_terms||[]).join(','),
    risk_category:(active.categories||[]).join(','),
    moderation_status:active.status,
    row_status:active.status,
    moderation_reason:active.moderation_reason,
    download_allowed:active.download_allowed?'true':'false',
    visual_mode:active.visual_mode,
    phrase_masked:active.phrase_visual,
    phrase_for_display:active.phrase_visual,
    phrase_display:active.phrase_visual,
    masked_visual:active.phrase_visual,
    moderation:active.status,
    status:active.status,
    moderation_categories:(active.categories||[]).join(','),
    moderation_checked_at:new Date().toISOString(),
    background:document.getElementById('bg').value,
    customer_name:(document.getElementById('cname').value||'').trim(),
    customer_phone:phoneForPim(),
    social_network:document.getElementById('csocial').value||'',
    social_nickname:(document.getElementById('cnick').value||'').trim(),
    consent_kvkk:'true', consent_publish:pub?'true':'false', consent_legal:'true',
    page_url:getSourcePageUrl(),
    iframe_url:location.href,
    referrer_url:document.referrer || '',
    user_agent:navigator.userAgent
