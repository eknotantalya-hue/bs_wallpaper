function vbP(s){ const p=s.split(/\s+/).map(Number); return {w:p[2],h:p[3]}; }
function sagAt(t,sag){ return 4*sag*t*(1-t); }
function sagSlope(t,sag,span){ return 4*sag*(1-2*t)/span; }

// Split raw input by | into rows (max 3)
function parseRows(raw){
  return bsUpper(raw).split('|').map(s=>s.trim()).filter(Boolean).slice(0,3);
}

// Strip % markers from row text for layout purposes
function stripAccent(text){ return text.replace(/%/g,''); }

// Black Symbols uppercase: product letters are uppercase.
// English lowercase i must become Latin I. Turkish uppercase İ stays İ when entered explicitly.
function bsUpper(text){
  return String(text||'')
    .replace(/i/g,'I')
    .replace(/ı/g,'I')
    .toUpperCase();
}

function normalizeInputValue(value, finalClean=false){
  let val = String(value||'');
  // Allow Latin, Turkish, Russian uppercase/lowercase, spaces, row separator | and accent marker %.
  val = val.replace(MANAGER_MODE ? /[^A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü |%*]/g : /[^A-Za-zА-ЯЁа-яёÇĞİÖŞÜçğıöşü |%]/g,'');
  val = val.replace(/ /g,' ');
  // No double spaces.
  val = val.replace(/ {2,}/g,' ');
  // No spaces around row separator.
  val = val.replace(/\s*\|\s*/g,'|');
  // No leading spaces at beginning of phrase or after each |.
  val = val.replace(/^ +/,'').replace(/\| +/g,'|');
  // During typing we keep one temporary trailing space so the next word can be typed.
  // On blur/download the trailing spaces are removed.
  if(finalClean){ val = val.split('|').map(seg=>seg.trim()).join('|'); }
  return bsUpper(val);
}

// Build color array per character: normal or accent
// "I %LOVE% YOU" -> chars I,space,L,O,V,E,space,Y,O,U
//                    cols  n  n  A  A  A  A  n    n  n  n
function buildColorMap(text, normalColor){
  const result = [];
  const parts = text.split('%');
  parts.forEach((part, i) => {
    const isAccent = (i % 2 === 1);
    for(const ch of Array.from(part)){
      result.push({ ch: bsUpper(ch), color: isAccent ? ACCENT : normalColor });
    }
  });
  return result;
}

// Count visible chars (no %, no |)
function visLen(raw){
  return raw.replace(/\|/g,'').replace(/%/g,'').replace(/\s+/g,' ').trim().length;
}

